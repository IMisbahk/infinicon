# Bun reference server
PORT=8787
HOST=0.0.0.0

# optional production storage
# DATABASE_URL=postgres://user:pass@host:5432/infinicon

# optional auth — when set, /v0/* requires Authorization: Bearer <key>
# INFINICON_API_KEY=

# background job runner poll interval (ms)
# JOB_POLL_MS=2000

# optional SDK client defaults
# INFINICON_BASE_URL=http://localhost:8787
