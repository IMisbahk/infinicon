{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinicon.dev/contracts/storage-ports.v0.schema.json",
  "title": "Storage Ports Contract Manifest v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "status",
    "source",
    "adapterCapabilityDescriptor",
    "ports",
    "openQuestions"
  ],
  "properties": {
    "spec": {
      "type": "string",
      "const": "storage-ports.v0"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "accepted"
      ]
    },
    "source": {
      "type": "string",
      "const": "../specs/storage-ports.v0.md"
    },
    "adapterCapabilityDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredDeclarations",
        "conditionallyRequiredDeclarations"
      ],
      "properties": {
        "requiredDeclarations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "implementedPorts",
              "transactionalGuarantees",
              "maximumObjectSizes",
              "indexConsistencyBehavior",
              "paginationBehavior",
              "supportedFilters"
            ]
          },
          "allOf": [
            {
              "contains": {
                "const": "implementedPorts"
              }
            },
            {
              "contains": {
                "const": "transactionalGuarantees"
              }
            },
            {
              "contains": {
                "const": "maximumObjectSizes"
              }
            },
            {
              "contains": {
                "const": "indexConsistencyBehavior"
              }
            },
            {
              "contains": {
                "const": "paginationBehavior"
              }
            },
            {
              "contains": {
                "const": "supportedFilters"
              }
            }
          ]
        },
        "conditionallyRequiredDeclarations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "when",
              "field"
            ],
            "properties": {
              "when": {
                "type": "string",
                "const": "productionReady = true"
              },
              "field": {
                "type": "string",
                "const": "backupRestoreExpectations"
              }
            }
          }
        }
      }
    },
    "ports": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "episodeStore",
        "graphStore",
        "indexStore",
        "metadataStore"
      ],
      "properties": {
        "episodeStore": {
          "$ref": "#/$defs/port"
        },
        "graphStore": {
          "$ref": "#/$defs/port"
        },
        "indexStore": {
          "$ref": "#/$defs/port"
        },
        "metadataStore": {
          "$ref": "#/$defs/port"
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "$defs": {
    "port": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredCapabilities",
        "requiredGuarantees"
      ],
      "properties": {
        "requiredCapabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredGuarantees": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
