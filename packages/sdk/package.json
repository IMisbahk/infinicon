{
  "name": "@infinicon/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the Infinicon memory API",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IMisbahk/infinicon.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bunx tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@infinicon/core-types": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
