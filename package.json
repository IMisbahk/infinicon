{
  "name": "infinicon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/agent-chat"
  ],
  "dependencies": {
    "@infinicon/core-types": "workspace:*",
    "@infinicon/plugin-host": "workspace:*"
  },
  "scripts": {
    "postinstall": "bun run scripts/bootstrap.ts",
    "start": "bun --env-file=.env run scripts/start.ts",
    "dev": "bun --env-file=.env run src/server.ts",
    "start:server": "bun --env-file=.env run src/server.ts",
    "check:spec-integrity": "python3 scripts/spec_integrity_check.py",
    "check:contracts": "python3 contracts/scripts/validate_contracts.py",
    "test:devops": "python3 -m unittest discover -s tests -v",
    "test": "bun test",
    "check": "bun test",
    "build": "bun build src/runtime/index.ts --outdir dist --target bun",
    "build:server": "bun build src/server.ts --outdir dist --target bun",
    "build:core-types": "bun build packages/core-types/src/index.ts --outdir packages/core-types/dist --target=node",
    "build:sdk": "bun build ./src/client.ts --outdir ./dist --target node",
    "test:core-types": "bun test packages/core-types/test",
    "test:plugin-host": "bun test packages/plugin-host/test",
    "test:sdk": "bun test test packages/sdk",
    "example:agent": "bun --env-file=.env run examples/agent-chat/src/main.ts",
    "example:simple": "bun --env-file=.env run examples/simple-chat.ts",
    "typecheck:sdk": "bunx tsc --noEmit",
    "verify": "bun test && python3 -m unittest discover -s tests -v && python3 contracts/scripts/validate_contracts.py"
  }
}
