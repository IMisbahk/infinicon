          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HydrateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hydrate result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HydrateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v0/assemble-context": {
      "post": {
        "operationId": "assembleContext",
        "summary": "Assemble bounded working context",
        "requestBody": {
          "required": true,
          "content": {
