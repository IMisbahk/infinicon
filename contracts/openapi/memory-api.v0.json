          "atom.extracted",
          "memory.indexed",
          "consolidation.started",
          "consolidation.completed",
          "consolidation.failed",
          "memory.disputed",
          "memory.superseded",
          "memory.tombstoned"
        ]
      },
      "SubscribeRequest": {
        "type": "object",
        "required": [
          "scope"
        ],
        "properties": {
          "scope": {
            "$ref": "#/components/schemas/Scope"
          },
