# Infinicon memory backend (run `bun run dev` from repo root, or your deployed URL)
INFINICON_BASE_URL=http://localhost:8787
INFINICON_API_KEY=

# Memory scope — isolates this agent's memory
INFINICON_TENANT_ID=demo
INFINICON_NAMESPACE_ID=agent-chat
INFINICON_AGENT_ID=assistant-1
INFINICON_SESSION_ID=

# LLM (optional — without this the agent runs in local echo mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Agent behavior
CONTEXT_MAX_TOKENS=2048
CONSOLIDATE_EVERY_TURNS=8
